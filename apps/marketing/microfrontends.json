{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "marketing": {
      "development": {
        "local": 3000,
        "fallback": "marketing.labs.vercel.dev"
      }
    },
    "blog": {
      "development": {
        "local": 3001
      },
      "routing": [
        {
          "group": "blog",
          "paths": ["/blog", "/blog/:path*"]
        }
      ]
    }
  }
}
